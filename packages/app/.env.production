# Production Environment Configuration

# Firebase (Production)
FIREBASE_API_KEY=AIzaSyD_prod_key_placeholder
FIREBASE_AUTH_DOMAIN=gativani.firebaseapp.com
FIREBASE_PROJECT_ID=gativani-prod
FIREBASE_STORAGE_BUCKET=gativani-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=prod_sender_id
FIREBASE_APP_ID=prod_app_id
FIREBASE_MEASUREMENT_ID=prod_measurement_id

# Sarvam AI (Production)
SARVAM_API_KEY=prod_sarvam_key
SARVAM_ENDPOINT=https://api.sarvam.ai
SARVAM_OCR_MODEL=ocr
SARVAM_TTS_MODEL=tts
SARVAM_TIMEOUT_SECONDS=30

# Gemini (Production)
GEMINI_API_KEY=prod_gemini_key
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=500
GEMINI_TEMPERATURE=0.7

# App Configuration
APP_NAME=GatiVani
APP_VERSION=1.0.0
APP_ENV=production
LOG_LEVEL=warning
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_DEBUGGER_UI=false

# API Configuration
API_TIMEOUT_SECONDS=30
ENABLE_OFFLINE_MODE=true
CACHE_DURATION_MINUTES=60
ENABLE_REQUEST_LOGGING=false
ENABLE_RESPONSE_LOGGING=false

# Performance & Monitoring
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true
SENTRY_DSN=https://prod_sentry_dsn
BACKEND_API_ENDPOINT=https://gativani.sohum.cloud/api
