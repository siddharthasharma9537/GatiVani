# HTTP
PORT=8788
NODE_ENV=production

# Gemini (Google AI Studio key works with free-tier model names below)
GEMINI_API_KEY=AIzaSyAX16bElcBQK-2odHHjl_FLMY2rAcC2px8
# Free / default model id for @google/generative-ai (no billing upgrade required for basic usage)
GEMINI_MODEL=gemini-2.0-flash

# Subscription tier page caps (processed pages sent to Gemini)
TIER_FREE_MAX_PAGES=5
TIER_STANDARD_MAX_PAGES=50
TIER_PREMIUM_MAX_PAGES=500

# When true, accept X-Subscription-Tier / X-Subscription-Active from the client (dev only).
# In production, perform server-side verification (JWT, Supabase, billing webhook) before trusting tier.
TRUST_CLIENT_TIER_HEADERS=false

# Azure Cognitive Services (Text-to-Speech)
# Get these from your Azure Speech resource in the Azure portal
AZURE_TTS_KEY=your-api-key-here
AZURE_TTS_REGION=centralindia
