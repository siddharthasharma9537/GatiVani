# Firebase Configuration (Get from Firebase Console)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Sarvam AI Configuration (Get from sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_ENDPOINT=https://api.sarvam.ai
SARVAM_OCR_MODEL=ocr
SARVAM_TTS_MODEL=tts
SARVAM_TIMEOUT_SECONDS=30

# Gemini AI Configuration (Get from aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=500
GEMINI_TEMPERATURE=0.7

# Firebase Storage Configuration
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
STORAGE_AUDIO_PATH=audio/
STORAGE_IMAGES_PATH=images/
STORAGE_METADATA_PATH=metadata/

# News API Configuration
NEWS_API_TYPE=telugu_custom
NEWS_CACHE_DURATION_MINUTES=30
NEWS_MAX_ARTICLES_PER_SOURCE=20

# App Configuration
APP_NAME=GatiVani
APP_VERSION=1.0.0
APP_ENV=demo
LOG_LEVEL=info
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=false
