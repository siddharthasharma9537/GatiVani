# Staging Environment Configuration

# Firebase (Staging)
FIREBASE_API_KEY=AIzaSyD_staging_key_placeholder
FIREBASE_AUTH_DOMAIN=gativani-staging.firebaseapp.com
FIREBASE_PROJECT_ID=gativani-staging
FIREBASE_STORAGE_BUCKET=gativani-staging.appspot.com
FIREBASE_MESSAGING_SENDER_ID=staging_sender_id
FIREBASE_APP_ID=staging_app_id
FIREBASE_MEASUREMENT_ID=staging_measurement_id

# Sarvam AI (Staging)
SARVAM_API_KEY=staging_sarvam_key
SARVAM_ENDPOINT=https://api.sarvam.ai
SARVAM_OCR_MODEL=ocr
SARVAM_TTS_MODEL=tts
SARVAM_TIMEOUT_SECONDS=30

# Gemini (Staging)
GEMINI_API_KEY=staging_gemini_key
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=500
GEMINI_TEMPERATURE=0.7

# App Configuration
APP_NAME=GatiVani Staging
APP_VERSION=1.0.0
APP_ENV=staging
LOG_LEVEL=info
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_DEBUGGER_UI=false

# API Configuration
API_TIMEOUT_SECONDS=30
ENABLE_OFFLINE_MODE=true
CACHE_DURATION_MINUTES=30
ENABLE_REQUEST_LOGGING=false
ENABLE_RESPONSE_LOGGING=false
