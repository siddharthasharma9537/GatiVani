# Development Environment Configuration

# Firebase (Dev)
FIREBASE_API_KEY=AIzaSyD_dev_key_placeholder
FIREBASE_AUTH_DOMAIN=gativani-dev.firebaseapp.com
FIREBASE_PROJECT_ID=gativani-dev
FIREBASE_STORAGE_BUCKET=gativani-dev.appspot.com
FIREBASE_MESSAGING_SENDER_ID=dev_sender_id
FIREBASE_APP_ID=dev_app_id
FIREBASE_MEASUREMENT_ID=dev_measurement_id

# Sarvam AI (Development)
SARVAM_API_KEY=dev_sarvam_key
SARVAM_ENDPOINT=https://api.sarvam.ai
SARVAM_OCR_MODEL=ocr
SARVAM_TTS_MODEL=tts
SARVAM_TIMEOUT_SECONDS=30

# Gemini (Development)
GEMINI_API_KEY=dev_gemini_key
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=500
GEMINI_TEMPERATURE=0.7

# App Configuration
APP_NAME=GatiVani Dev
APP_VERSION=1.0.0
APP_ENV=development
LOG_LEVEL=debug
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_DEBUGGER_UI=true

# API Configuration
API_TIMEOUT_SECONDS=30
ENABLE_OFFLINE_MODE=true
CACHE_DURATION_MINUTES=10
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true
BACKEND_API_ENDPOINT=https://gativani.sohum.cloud/api
